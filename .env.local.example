# Copy to .env.local (gitignored) and fill in, or export these in your shell.
# Used by scripts/bootstrap-infra.sh and scripts/deploy.sh.

# ── AWS (us-east-1 required for CloudFront) ──────────────────
# Prefer `aws configure` / IAM role / SSO when possible; env vars are fine too.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Cloudflare (DNS for preview.hiq.earth / cortex.hiq.earth) ─
# Global API Key + account email. Alternatively, use a scoped API token
# with Zone:DNS:Edit — would require minor tweak to cf_api() helper.
# CF_API_KEY=
# CF_ZONE_ID=
# CF_EMAIL=

# ── Optional overrides ───────────────────────────────────────
# DOMAIN=preview.hiq.earth
# BUCKET=cortex-trail-preview
