---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Asterism from '@/components/Asterism.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = 'BOM Matching — HiQ Cortex';
const description =
  'Upload a Bill of Materials. Cortex returns top-k emission factor candidates per line — DQI scored, every citation linked to the source.';

const steps = [
  {
    n: '01',
    title: 'Upload or paste',
    body:
      'Excel, CSV, or pasted text. No schema required. Cortex reads columns as a colleague would — names, specs, quantities, whatever free-form notes came with the BOM.',
  },
  {
    n: '02',
    title: 'Clarify where it matters',
    body:
      'For ambiguous rows — "aluminum", "steel", "plastic" — Cortex asks one or two questions before searching. Alloy grade, production route, region. Silence on low-signal fields.',
  },
  {
    n: '03',
    title: 'Search wide, score honest',
    body:
      'HiQLCD, Ecoinvent, EF, CarbonMinds, and more — searched in parallel. Each candidate comes back with a Data Quality Indicator (DQI), system model, and a clickable source URL.',
  },
  {
    n: '04',
    title: 'Human-in-the-loop at the thresholds',
    body:
      "Cortex pauses where automation would break an audit — coverage gaps, proxy substitutions, large cross-database spread, restricted-data markers, ambiguous system-model matches. You decide — the agent doesn't silently pick.",
  },
  {
    n: '05',
    title: 'Deliver with provenance',
    body:
      'Export to Excel with matched dataset, source database, region, DQI, system model, match type (exact / proxy / low-DQI), and notes. Every cell auditable back to the original factor.',
  },
];

const vsWatershed = [
  {
    them: 'Upload → minutes → one PCF number.',
    us: 'Upload → clarifying questions → top-k candidates → your approved match → PCF with every assumption attached.',
    note: 'Speed is a side effect. Auditability is the product.',
  },
  {
    them: 'AI decomposes the product automatically.',
    us: 'AI proposes. The expert decides. Coverage, proxy use, and cross-database disagreements are never silent.',
    note: "If a machine can't explain why it picked factor A over B, neither can you when the auditor asks.",
  },
  {
    them: 'Confidence score from a model.',
    us: 'DQI — the ISO-recognized Data Quality Indicator. Same vocabulary your reviewers use.',
    note: "Use the industry's words. Don't invent new ones that need translating.",
  },
];

const outputFields = [
  'Material name (as provided)',
  'Matched dataset key + URL',
  'Source database (HiQLCD / Ecoinvent / EF / CarbonMinds)',
  'Region · Unit · System model',
  'DQI score',
  'Match type: exact · proxy · low-DQI',
  'Notes (what was substituted and why)',
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="relative">
    <div class="container-page pt-14 md:pt-20 pb-10">
      <div class="mb-10 flex items-baseline justify-between border-b border-rule pb-4">
        <p class="eyebrow">Solutions · BOM Matching</p>
        <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
      </div>
      <h1 class="font-display" style="font-size: clamp(2.2rem, 5.5vw, 4.5rem); line-height: 1.03; letter-spacing: -0.02em; font-variation-settings: 'SOFT' 40, 'opsz' 144; font-weight: 400; max-width: 20ch;">
        Every line in your BOM deserves the same question an expert would ask.
      </h1>
      <p class="mt-10 max-w-2xl font-serif italic" style="font-size: 1.2rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        Cortex reads a Bill of Materials the way a practiced LCA consultant reads it — noticing
        which rows are clear, which are underspecified, and which need to be argued about before
        any number is assigned.
      </p>
    </div>
  </section>

  <!-- Steps -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="The flow" numeral="I" title="Five steps, always in order." />

      <div class="grid gap-px overflow-hidden border border-rule md:grid-cols-2 lg:grid-cols-3" style="background: var(--rule);">
        {steps.map((s) => (
          <article class="p-8 md:p-10 flex flex-col gap-4" style="background: var(--paper);">
            <div class="flex items-baseline justify-between">
              <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: 1.4rem;">{s.n}</span>
              <span class="eyebrow">step</span>
            </div>
            <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 40; font-size: 1.45rem; line-height: 1.15; letter-spacing: -0.01em;">{s.title}</h3>
            <p class="font-serif" style="line-height: 1.55; font-variation-settings: 'opsz' 17; color: var(--ink); font-size: 0.98rem;">{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="How we differ" numeral="II" title="Speed without provenance is a number you can't defend." />

      <p class="max-w-3xl font-serif" style="font-size: 1.14rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Most AI-for-PCF tools race to a single number. We race to a line of reasoning you can
        hand a regulator. Here's where the two approaches diverge.
      </p>

      <div class="mt-12 border-y border-rule">
        {vsWatershed.map((row, i) => (
          <div class="grid border-b border-rule last:border-b-0 md:grid-cols-[1fr_1.2fr]">
            <div class="border-b border-rule p-8 md:border-b-0 md:border-r md:p-10">
              <div class="flex items-center gap-3 mb-3">
                <span class="eyebrow">Typical AI-for-PCF</span>
              </div>
              <p class="font-serif" style="font-size: 1.02rem; line-height: 1.5; font-variation-settings: 'opsz' 18; color: var(--ink-faint);">{row.them}</p>
            </div>
            <div class="p-8 md:p-10">
              <div class="flex items-center gap-3 mb-3">
                <span class="eyebrow" style="color: var(--shell);">Cortex</span>
                <span class="font-display italic" style="color: var(--shell); font-size: 0.95rem; font-variation-settings: 'SOFT' 40;">§ {i + 1}</span>
              </div>
              <p class="font-serif font-medium" style="font-size: 1.05rem; line-height: 1.5; font-variation-settings: 'opsz' 18; color: var(--ink);">{row.us}</p>
              <p class="mt-4 font-serif italic" style="font-size: 0.9rem; line-height: 1.5; font-variation-settings: 'opsz' 14; color: var(--ink-faint);">
                <span class="eyebrow mr-2">note</span>{row.note}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Output -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="The output" numeral="III" title="One spreadsheet. Ten columns of accountability." />

      <div class="grid gap-12 md:grid-cols-[1.1fr_1fr] md:gap-16">
        <div class="max-w-xl">
          <p class="font-serif" style="font-size: 1.14rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
            Every export contains the fields reviewers look for first: matched dataset, source
            database, region, DQI, system model, match type, proxy notes. The coverage gap is
            its own sheet, not a footnote.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/chat" class="ticket">Upload a BOM now</a>
            <a href="/standards" class="ticket-ghost">See standards alignment</a>
          </div>
        </div>

        <div>
          <div class="eyebrow mb-4">Exported fields</div>
          <ul class="space-y-0">
            {outputFields.map((f, i) => (
              <li class="row-line">
                <span class="num">{String(i + 1).padStart(2, '0')}</span>
                <span class="font-serif" style="font-variation-settings: 'opsz' 18; color: var(--ink);">{f}</span>
                <span class="font-mono" style="font-size: 0.72rem; color: var(--ink-whisper); letter-spacing: 0.06em;">col.</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
