---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = '定价 — HiQ Cortex';
const description =
  '三档方案。免费起步。Pro €99/月，Plus €299/月含 Cortex Cowork 桌面端。数据库授权要求说清楚。';

const plans = [
  {
    name: 'Free',
    price: '€0',
    period: '',
    items: [
      ['LLM 预算',     '$10 / 月'],
      ['速率上限',     '30 rpm · 2M tpm'],
      ['数据库检索',   '基础版'],
      ['对话记忆',     '—'],
      ['Cortex Cowork', '—'],
      ['文件读写',     '—'],
      ['技能市场',     '—'],
    ],
  },
  {
    name: 'Pro',
    price: '€99',
    period: '/月 · 或 €297/季',
    items: [
      ['LLM 预算',     '$500 / 月'],
      ['速率上限',     '100 rpm · 10M tpm'],
      ['数据库检索',   '14 个 LCA 数据库'],
      ['对话记忆',     '是'],
      ['Cortex Cowork', '—'],
      ['文件读写',     '—'],
      ['技能市场',     '—'],
    ],
  },
  {
    name: 'Plus',
    price: '€299',
    period: '/月 · 或 €897/季',
    items: [
      ['LLM 预算',     '$500 / 月'],
      ['速率上限',     '200 rpm · 20M tpm'],
      ['数据库检索',   '14 个 LCA 数据库'],
      ['对话记忆',     '是'],
      ['Cortex Cowork', '是'],
      ['文件读写',     '是'],
      ['技能市场',     '是'],
    ],
    highlight: true,
  },
];

const apiTiers = [
  ['uplink-free', '30 rpm'],
  ['uplink-pro',  '100 rpm'],
  ['uplink-plus', '200 rpm'],
];

const faqs = [
  {
    q: '订阅可以取消吗？',
    a: '可以。通过 Desktop 设置 → 账单 → 管理订阅，进入客户账单门户自助取消。当前计费周期结束后，方案自动恢复为 Free。',
  },
  {
    q: '季付有折扣吗？',
    a: '没有。季付是三个月按月费叠加，不额外打折。',
  },
  {
    q: 'Plus 包含 Cortex Chat 吗？',
    a: '包含。Plus 涵盖 Pro 的全部内容（Chat、14 个数据库、对话记忆），并在此基础上增加 Cortex Cowork。',
  },
  {
    q: '有团队版或企业方案吗？',
    a: '有。团队和企业配置由 HiQ 团队直接开通。请发邮件至 contact@hiq.earth 洽谈。',
  },
];
---

<BaseLayout title={title} description={description} locale="zh">

  <!-- Hero -->
  <section class="relative">
    <div class="container-page pt-14 md:pt-20 pb-14">
      <div class="mb-10 flex items-baseline justify-between border-b border-rule pb-4">
        <p class="eyebrow">定价</p>
        <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
      </div>
      <h1 class="font-display" style="font-size: clamp(2.2rem, 5.5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; font-variation-settings: 'SOFT' 40, 'opsz' 144; font-weight: 400;">
        三档方案。<span style="color: var(--ink-faint);">免费起步。</span>
      </h1>
      <p class="mt-10 max-w-2xl font-serif italic" style="font-size: 1.18rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        Free、Pro、Plus 三档。LLM 预算、速率上限、Cowork 开通条件，逐项说明，不留模糊空间。
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#plans" class="ticket">查看方案 <span aria-hidden="true">↓</span></a>
        <a href="/zh/chat" class="ticket-ghost">免费试用</a>
      </div>
    </div>
  </section>

  <!-- §I Plan grid -->
  <section id="plans" class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="方案" numeral="I" title="自助开通。随时取消。" />
      <p class="max-w-2xl font-serif" style="font-size: 1.05rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
        三档方案。通过 Desktop 设置 → 账单自助开通，随时经账单门户取消。
      </p>

      <div class="mt-10 grid gap-px overflow-hidden border border-rule md:grid-cols-3" style="background: var(--rule);">
        {plans.map((p) => (
          <article class="p-7 md:p-8" style={`background: var(--paper); ${p.highlight ? 'border-top: 3px solid var(--shell);' : ''}`}>
            <div class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 36; font-size: 1.5rem; line-height: 1.05; color: var(--ink);">{p.name}</div>
            <div class="mt-3">
              <span class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: 2.4rem; line-height: 1; color: var(--shell);">{p.price}</span>
              {p.period && <span class="ml-1 font-serif" style="font-size: 0.9rem; color: var(--ink-mute);">{p.period}</span>}
            </div>
            <ul class="mt-7 space-y-3 font-serif" style="font-size: 0.92rem; line-height: 1.5; font-variation-settings: 'opsz' 16;">
              {p.items.map(([label, val]) => (
                <li class="grid grid-cols-[1fr_auto] gap-3">
                  <span style="color: var(--ink-mute);">{label}</span>
                  <span style={`color: ${val === '—' ? 'var(--ink-faint)' : 'var(--ink)'}; font-variant-numeric: tabular-nums;`}>{val}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <p class="mt-10 max-w-2xl font-serif italic" style="font-size: 0.95rem; line-height: 1.55; font-variation-settings: 'opsz' 16; color: var(--ink-mute);">
        季付为三个月月费叠加，无额外折扣。升级方案时，当前周期已用天数按比例结算。
      </p>
    </div>
  </section>

  <!-- §II What each tier includes -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="各档包含内容" numeral="II" title="数字说话。" />
      <div class="max-w-3xl space-y-5 font-serif" style="font-size: 1.05rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        <p>
          <strong style="font-weight: 500;">Free</strong> 每月含 $10 LLM 预算，提供基础数据库检索，无需信用卡即可开始使用。速率上限 30 rpm，用于探索性查询和偶发性查找已够用。
        </p>
        <p>
          <strong style="font-weight: 500;">Pro</strong>（€99/月）将 LLM 预算提升至 $500，开放 Cortex 所检索的全部 14 个 LCA 数据库，含 Ecoinvent、CarbonMinds 和 HiQLCD-AL。对话记忆跨会话持久保存，并跨设备同步。Pro 不含 Cortex Cowork，交互界面为 Chat。
        </p>
        <p>
          <strong style="font-weight: 500;">Plus</strong>（€299/月）在 Pro 基础上增加 Cortex Cowork 桌面端：本机运行的 agent，可读写文件、执行多步骤工作流、从技能市场加载技能。Cowork 会话在本地运行，agent 与桌面应用运行在同一台机器上，不经远程服务器。Plus 沿用与 Pro 相同的 $500 LLM 预算，速率上限更高（200 rpm · 20M tpm）。
        </p>
      </div>
    </div>
  </section>

  <!-- §III Database licensing -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="必要说明" numeral="III" title="数据库授权。" />
      <div class="max-w-3xl space-y-5 font-serif" style="font-size: 1.05rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        <p>
          Cortex 代替用户检索 Ecoinvent、CarbonMinds 和 HiQLCD-AL。订阅 Cortex，不等于获得上述数据提供方对其数据集的授权许可。
        </p>
        <p>
          Ecoinvent 和 CarbonMinds 各需向数据提供方单独购买授权。HiQLCD-AL 为 HiQ-AI 自有数据集，全体 Cortex 订阅用户均可访问。
        </p>
        <p>
          若账户未持有有效的 Ecoinvent 或 CarbonMinds 授权，Cortex 将从其可访问的数据库中检索，并在输出中注明缺口。输出结果经得起审计——它如实反映实际检索范围。
        </p>
      </div>
    </div>
  </section>

  <!-- §IV API tiers -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="API 接入" numeral="IV" title="Uplink 档位。" />
      <p class="max-w-3xl font-serif" style="font-size: 1.05rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        开发者将 Cortex 集成至外部工具时，通过 <code style="font-family: 'JetBrains Mono', monospace; font-size: 0.9em;">x.hiqlcd.com/api/cortex/*</code> 加 API key 接入平台。三个 uplink 档位可选：
      </p>

      <div class="mt-8 max-w-md overflow-hidden border border-rule" style="background: var(--paper);">
        <table class="w-full" style="border-collapse: collapse;">
          <thead>
            <tr style="background: var(--paper-rim);">
              <th class="eyebrow text-left p-4 border-b border-rule">档位</th>
              <th class="eyebrow text-left p-4 border-b border-rule">速率上限</th>
            </tr>
          </thead>
          <tbody class="font-mono" style="font-size: 0.85rem;">
            {apiTiers.map(([tier, rate]) => (
              <tr>
                <td class="p-4 border-b border-rule last:border-b-0" style="color: var(--ink);">{tier}</td>
                <td class="p-4 border-b border-rule last:border-b-0" style="color: var(--ink);">{rate}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-6 max-w-3xl font-serif" style="font-size: 1rem; line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink-mute);">
        API key 申请和档位升级由 HiQ 团队处理，暂无自助控制台。速率上限即为硬性天花板，超出后返回 <code style="font-family: 'JetBrains Mono', monospace; font-size: 0.9em;">429</code>。
      </p>
      <p class="mt-4 max-w-3xl font-serif" style="font-size: 1rem; line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink);">
        申请接入：<a href="mailto:contact@hiq.earth" style="color: var(--shell);">contact@hiq.earth</a>
      </p>
    </div>
  </section>

  <!-- §V FAQ -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="常见问题" numeral="V" title="" />
      <div class="max-w-3xl space-y-7 font-serif" style="font-size: 1.02rem; line-height: 1.65; font-variation-settings: 'opsz' 18; color: var(--ink);">
        {faqs.map((f) => (
          <div>
            <p class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.05rem; color: var(--ink);">{f.q}</p>
            <p class="mt-2" style="color: var(--ink);">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing -->
  <section class="border-t border-rule">
    <div class="container-prose py-24 text-center">
      <h2 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 96; font-size: clamp(2rem, 5vw, 3rem); line-height: 1.05; letter-spacing: -0.02em;">
        从一个问题开始。
      </h2>
      <p class="mx-auto mt-8 max-w-xl font-serif italic" style="font-size: 1.05rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        Free 含每月 $10 LLM 预算：足够跑一次材料查询、将 BOM 一行数据与 14 个数据库比对，或提一个 Scope 3 分类问题。无需信用卡。
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/zh/chat" class="ticket">免费试用 <span aria-hidden="true">→</span></a>
        <a href="mailto:contact@hiq.earth" class="ticket-ghost">API 接入咨询</a>
      </div>
    </div>
  </section>
</BaseLayout>
