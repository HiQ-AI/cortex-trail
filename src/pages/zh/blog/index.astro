---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionMark from '@/components/SectionMark.astro';
import { getCollection } from 'astro:content';

const title = '博客 — HiQ Cortex';
const description = 'LCA、AI 与「慢答案」的实践笔记。';

const entries = (await getCollection('blog', ({ data }) => !data.draft && data.locale === 'zh'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title={title} description={description} locale="zh">

  <section class="container-page pt-14 md:pt-20 pb-14">
    <div class="mb-10 flex items-baseline justify-between border-b border-rule pb-4">
      <p class="eyebrow">博客</p>
      <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
    </div>
    <h1 class="font-display" style="font-size: clamp(2.2rem, 5.5vw, 4.5rem); line-height: 1.15; letter-spacing: -0.01em; font-variation-settings: 'SOFT' 40, 'opsz' 144; font-weight: 400; max-width: 22ch;">
      LCA、AI 与慢答案的实践笔记。
    </h1>
    <p class="mt-10 max-w-2xl font-serif italic" style="font-size: 1.12rem; line-height: 1.75; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
      关于碳核算的实际工作机制、最近读到的东西，以及上周做错的事情——简短的现场调度。
    </p>
  </section>

  <section class="border-t border-rule">
    <div class="container-page py-16 md:py-20">
      {entries.length === 0 ? (
        <div class="max-w-2xl">
          <SectionMark kicker="第一卷" numeral="I" title="首篇文章在路上。" />
          <p class="font-serif italic" style="font-size: 1.08rem; line-height: 1.85; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
            首篇文章正在校对中。它会讲为什么 Cortex 返回 top-k 而不是 top-1，以及一条推理链坍塌成单一数字时，行业失去了什么。请稍候，或先读
            <a href="/zh/standards" style="color: var(--shell-dim);">标准对齐</a>。
          </p>
        </div>
      ) : (
        <ul class="border-y border-rule">
          {entries.map((e) => (
            <li class="border-b border-rule last:border-b-0">
              <a href={`/blog/${e.id}`} class="group grid grid-cols-[7rem_1fr_auto] items-baseline gap-6 py-8 md:py-10" style="text-decoration: none;">
                <span class="font-mono" style="font-size: 0.72rem; letter-spacing: 0.08em; color: var(--ink-faint);">
                  {e.data.publishDate.toISOString().slice(0, 10)}
                </span>
                <div>
                  <h2 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 40; font-size: clamp(1.4rem, 2.4vw, 1.8rem); line-height: 1.2; letter-spacing: -0.01em; color: var(--ink);">
                    {e.data.title}
                  </h2>
                  <p class="mt-3 font-serif max-w-2xl" style="line-height: 1.85; font-variation-settings: 'opsz' 18; color: var(--ink-mute);">
                    {e.data.description}
                  </p>
                </div>
                <span class="smallcaps transition-transform group-hover:translate-x-0.5" aria-hidden="true" style="text-decoration: none; color: var(--ink-mute);">阅读 →</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
