---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Asterism from '@/components/Asterism.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = 'HiQ Cortex — An LCA workbench you can defend, line by line.';
const description =
  'Unlike general AI, Cortex is built specifically for LCA: authoritative databases, direct integration with professional LCA software, full reasoning chain at every step.';

// Two products — body trimmed for landing-page weight
const products = [
  {
    name: 'Cortex Chat',
    label: 'CORTEX CHAT · WEB',
    body:
      'Ask in Chinese or English. Cortex asks one clarifying question first: alloy grade, region, time window. Then it queries the LCA databases scoped to that case, and returns ranked candidates with sources. No averaging, no single number.',
    primary: { href: '/chat', label: 'Open Cortex Chat' },
    secondary: { href: '/product/chat', label: 'Product overview' },
  },
  {
    name: 'Cortex Cowork',
    label: 'CORTEX COWORK · DESKTOP',
    body:
      'Runs on your machine. Reads your project files, drives openLCA locally, writes each substitution decision into a versioned log inside the project. The log persists with the project, walkable on review.',
    primary: { href: 'https://github.com/HiQ-AI/cortex-desktop/releases/latest', label: 'Download Cortex Desktop' },
    secondary: { href: '/product/cowork', label: 'Product overview' },
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- ═══ Hero ═══ -->
  <section class="relative overflow-hidden">
    <div class="container-page pt-14 md:pt-20 pb-24 md:pb-32">

      <div class="rise rise-1 mb-10 border-b border-rule pb-4">
        <p class="eyebrow">HiQ Cortex · An LCA workbench</p>
      </div>

      <div class="relative">
        <h1 class="rise rise-2 font-display" style="font-size: clamp(3rem, 9vw, 7rem); line-height: 1.02; letter-spacing: -0.03em; font-variation-settings: 'SOFT' 30, 'opsz' 144; font-weight: 400;">
          An <em style="color: var(--shell); font-style: italic; font-variation-settings: 'SOFT' 80, 'opsz' 144;">LCA workbench</em><br/>
          you can defend,<br/>
          <span style="color: var(--ink-faint);">line by line.</span>
        </h1>

        <p class="rise rise-3 mt-12 max-w-3xl font-serif italic" style="font-size: clamp(1.15rem, 1.6vw, 1.4rem); line-height: 1.55; font-variation-settings: 'opsz' 24; color: var(--ink);">
          Unlike general AI, Cortex is built specifically for LCA: authoritative databases, direct integration with professional LCA software, full reasoning chain at every step.
        </p>

        <div class="rise rise-5 mt-14 flex flex-wrap items-center gap-4">
          <a href="/chat" class="ticket">Try Cortex Chat <span aria-hidden="true">→</span></a>
          <a href="/product/chat" class="ticket-ghost">See how it works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Data work stat ═══ -->
  <section class="border-t border-rule">
    <div class="container-page py-12 md:py-14">
      <p class="max-w-3xl font-serif italic" style="font-size: clamp(1.12rem, 1.7vw, 1.35rem); line-height: 1.65; font-variation-settings: 'opsz' 24; color: var(--ink);">
        60–70% of every LCA project is data work — collecting, processing, matching supplier data to authoritative datasets. HiQ-AI built Cortex for exactly that.
      </p>
    </div>
  </section>

  <!-- ═══ Two products ═══ -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="One engine, two surfaces" numeral="I" title="Chat answers questions. Cowork runs workflows." />

      <div class="mt-14 grid gap-px overflow-hidden border border-rule md:grid-cols-2" style="background: var(--rule);">
        {products.map((p) => (
          <article class="p-10 md:p-12 flex flex-col gap-5" style="background: var(--paper);">
            <p class="eyebrow" style="color: var(--shell);">{p.label}</p>
            <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: clamp(1.8rem, 3vw, 2.4rem); line-height: 1.05; letter-spacing: -0.02em;">{p.name}</h3>
            <p class="font-serif" style="line-height: 1.65; font-variation-settings: 'opsz' 18; color: var(--ink); font-size: 1.02rem;">{p.body}</p>
            <div class="mt-auto flex flex-wrap items-center gap-4 pt-4">
              <a href={p.primary.href} class="ticket">{p.primary.label} <span aria-hidden="true">→</span></a>
              <a href={p.secondary.href} class="smallcaps" style="text-decoration: none; color: var(--ink-mute);">{p.secondary.label} →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ Closing ═══ -->
  <section class="border-t border-rule">
    <div class="container-prose py-24 text-center">
      <Asterism class="mb-10" />
      <h2 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 96; font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.02; letter-spacing: -0.02em;">
        Start with one question.
      </h2>
      <p class="mx-auto mt-8 max-w-xl font-serif italic" style="font-size: 1.12rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        You don't need everything in hand. A material name, a process question, a factor you're uncertain about — any of these is a starting point. Cortex shows the reasoning.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/chat" class="ticket">Try Cortex Chat <span aria-hidden="true">→</span></a>
        <a href="/pricing" class="ticket-ghost">See pricing</a>
      </div>
      <p class="mt-6 font-mono" style="font-size: 0.78rem; letter-spacing: 0.06em; color: var(--ink-faint);">
        <a href="mailto:info@hiqlcd.com" style="color: var(--ink-faint); text-decoration: none;">info@hiqlcd.com</a>
      </p>
    </div>
  </section>

</BaseLayout>
