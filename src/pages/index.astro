---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SnailGlyph from '@/components/SnailGlyph.astro';
import Asterism from '@/components/Asterism.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = 'HiQ Cortex — The slow answer to carbon accounting';
const description =
  'A thin intelligence layer above every LCA database — compressing understand → search → cross-check → auditable answer into a single conversation.';

const qualities = [
  {
    numeral: 'I',
    key: 'Slow',
    body:
      "It won't skip the boundary discussion to hand you a number. Every answer waits until the right questions have been asked: system boundary, allocation rule, geographic fit.",
    aside: 'Speed is a side effect. The deliverable is a line of reasoning.',
  },
  {
    numeral: 'II',
    key: 'Shell',
    body:
      "Wherever the snail goes, it carries its shell. Every cited dataset, every proxy assumption, every version switch stays attached to the answer. Reviewers can see exactly what Cortex saw.",
    aside: 'Provenance is a field, not a footnote.',
  },
  {
    numeral: 'III',
    key: 'Trail',
    body:
      'Regulators, auditors, and legal teams can follow the trail back to the origin. The line between a conversation and an audit-grade report is the product.',
    aside: "If a number can't be defended, it can't be used.",
  },
];

const useCases = [
  {
    ord: '01',
    label: 'BOM Matching',
    href: '/solutions/bom-matching',
    blurb:
      'Upload a Bill of Materials. Cortex returns top-k emission factor candidates per line — DQI scored, every citation linked back to source.',
    proof: '100-row BOM · ~10 min · full provenance',
  },
  {
    ord: '02',
    label: 'Carbon Search',
    href: '/solutions/carbon-search',
    blurb:
      'Ask in Chinese or English. Cortex searches HiQLCD, Ecoinvent, EF, CarbonMinds, and more in parallel — returning ranked candidates with unit and region disambiguation.',
    proof: 'Multi-database · zh + en · unit-aware',
  },
  {
    ord: '03',
    label: 'Cowork',
    href: '/solutions/cowork',
    blurb:
      'A local agent that keeps working when the conversation ends. Cortex Desktop holds context across sessions, runs tools on your machine, and syncs a shared workbench.',
    proof: 'Desktop agent · local workspace · cross-session memory',
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- ═══ Hero ═══ -->
  <section class="relative overflow-hidden">
    <div class="container-page pt-14 md:pt-20 pb-24 md:pb-32">

      <div class="rise rise-1 mb-10 flex items-baseline justify-between border-b border-rule pb-4">
        <p class="eyebrow">HiQ Cortex · A product of HiQ-AI</p>
        <p class="hidden sm:block" style="font-family: 'Newsreader Variable', serif; font-variation-settings: 'opsz' 14; font-style: italic; color: var(--ink-faint); font-size: 0.86rem;">
          Vol. 01 · On the slow answer
        </p>
        <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
      </div>

      <div class="grid gap-10 md:grid-cols-[1.25fr_1fr] md:gap-14 items-start">

        <div class="relative">
          <h1 class="rise rise-2 font-display" style="font-size: clamp(3rem, 8.5vw, 7.5rem); line-height: 0.95; letter-spacing: -0.025em; font-variation-settings: 'SOFT' 30, 'opsz' 144; font-weight: 400;">
            The <em style="color: var(--shell); font-style: italic; font-variation-settings: 'SOFT' 80, 'opsz' 144;">slow</em><br/>
            answer to<br/>
            <span style="color: var(--ink);">carbon</span><br/>
            <span style="color: var(--ink-faint);">accounting.</span>
          </h1>

          <p class="rise rise-3 dropcap mt-10 max-w-xl font-serif" style="font-size: 1.14rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink);">
            A thin intelligence layer above every LCA database. It compresses
            <span class="font-mono" style="font-size: 0.88em; color: var(--shell-dim);"> understand → search → cross-check → auditable answer</span>
            into a single conversation.
          </p>

          <p class="rise rise-4 mt-6 max-w-xl font-serif italic" style="font-variation-settings: 'opsz' 14; color: var(--ink-faint);">
            It doesn't replace experts. It scales their judgment.
          </p>

          <div class="rise rise-5 mt-12 flex flex-wrap items-center gap-4">
            <a href="/chat" class="ticket">Try Cortex Chat <span aria-hidden="true">→</span></a>
            <a href="/solutions/bom-matching" class="ticket-ghost">See a BOM walkthrough</a>
          </div>
        </div>

        <aside class="relative rise rise-3 md:pt-6">
          <div class="relative flex justify-center md:justify-end" style="color: var(--ink);">
            <SnailGlyph class="w-full max-w-md" />
          </div>
          <div class="margin-note mt-6 md:mt-10 grid gap-4 sm:grid-cols-2">
            <div>
              <span class="eyebrow block mb-2">fig. 1</span>
              <em>Cornu aspersum</em>, rendered as a house you take everywhere.
              Shell carries what the body won't remember. Trail carries what others will audit.
            </div>
            <div>
              <span class="eyebrow block mb-2">on slowness</span>
              A CBAM filing is weeks of boundary debates, BOM decomposition, and
              trade-offs across a dozen databases. The bottleneck is not data —
              it is who reads the question right.
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══ Three qualities ═══ -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="Why a snail" numeral="I–III" title="We picked the opposite of a rocket, on purpose." />

      <div class="grid max-w-5xl gap-10 md:grid-cols-2">
        <p class="font-serif" style="font-size: 1.14rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
          The industry's AI mascot is a lightning bolt. LCA has never been that kind of industry.
          One CBAM filing is built out of weeks of boundary debates, BOM decomposition, and
          trade-offs across a dozen databases — every step of which must be auditable, challenged,
          and traced.
        </p>
        <p class="font-serif italic" style="font-size: 1.02rem; line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink-faint);">
          We picked a snail. It is slow by constitution, carries its house,
          and leaves a trail you can trace.
        </p>
      </div>

      <div class="mt-16 grid gap-px overflow-hidden border border-rule md:grid-cols-3" style="background: var(--rule);">
        {qualities.map((q) => (
          <article class="p-8 md:p-10 flex flex-col gap-5" style="background: var(--paper);">
            <div class="flex items-baseline justify-between">
              <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.25rem;">§ {q.numeral}</span>
              <span class="eyebrow">{q.key}</span>
            </div>
            <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.05; letter-spacing: -0.015em;">{q.key}</h3>
            <p class="font-serif" style="line-height: 1.55; font-variation-settings: 'opsz' 18; color: var(--ink);">{q.body}</p>
            <p class="mt-auto font-serif italic" style="font-size: 0.92rem; line-height: 1.5; font-variation-settings: 'opsz' 14; color: var(--ink-faint);">
              <span class="eyebrow mr-2" style="color: var(--shell);">note</span>{q.aside}
            </p>
          </article>
        ))}
      </div>

      <Asterism />

      <blockquote class="mx-auto max-w-3xl text-center">
        <p class="pullquote">
          Cortex does the fastest things on the backend. What it delivers is always the slowest thing:
          <em style="color: var(--shell); font-style: italic;">a chain of reasoning you can audit, line by line.</em>
        </p>
        <footer class="eyebrow mt-6">Slow is the most important promise we can make.</footer>
      </blockquote>
    </div>
  </section>

  <!-- ═══ Use cases ═══ -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="What it does" numeral="IV" title="One cortex. Three surfaces." />

      <div class="max-w-3xl">
        <p class="font-serif" style="font-size: 1.14rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
          The same reasoning engine, wherever you meet your LCA data — at the material level,
          at the BOM level, at the desktop where the real work happens.
        </p>
      </div>

      <div class="mt-14 border-y border-rule">
        {useCases.map((uc) => (
          <a href={uc.href} class="group grid grid-cols-[3.5rem_1fr_auto] items-baseline gap-8 py-8 md:grid-cols-[4.5rem_1fr_auto] md:gap-10 md:py-10 border-b border-rule last:border-b-0 transition-colors hover:bg-paper-100" style="text-decoration: none;">
            <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: clamp(1.6rem, 2.5vw, 2rem);">{uc.ord}</span>
            <div>
              <h3 class="font-display mb-2" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: clamp(1.6rem, 2.8vw, 2.2rem); line-height: 1.1; letter-spacing: -0.015em; color: var(--ink);">{uc.label}</h3>
              <p class="font-serif max-w-2xl" style="line-height: 1.55; font-variation-settings: 'opsz' 18; color: var(--ink);">{uc.blurb}</p>
              <p class="mt-4 font-mono" style="font-size: 0.72rem; letter-spacing: 0.06em; color: var(--ink-faint);">{uc.proof}</p>
            </div>
            <span class="smallcaps transition-transform group-hover:translate-x-0.5" aria-hidden="true" style="text-decoration: none; color: var(--ink-mute);">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ Closing ═══ -->
  <section class="border-t border-rule">
    <div class="container-prose py-24 text-center">
      <Asterism class="mb-10" />
      <h2 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 96; font-size: clamp(2rem, 5vw, 4rem); line-height: 1; letter-spacing: -0.02em;">
        Start with one question.
      </h2>
      <p class="mx-auto mt-8 max-w-xl font-serif italic" style="font-size: 1.14rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        Paste a material name. Upload a BOM. Ask whether that emission factor holds for
        a Chinese supplier. Cortex answers — and shows its work.
      </p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a href="/chat" class="ticket">Open Cortex Chat</a>
        <a href="/methodology" class="ticket-ghost">Read the methodology</a>
      </div>
    </div>
  </section>

</BaseLayout>
