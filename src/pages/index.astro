---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SnailGlyph from '@/components/SnailGlyph.astro';
import Asterism from '@/components/Asterism.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = 'HiQ Cortex — A reasoning layer above every LCA database';
const description =
  'Cortex matches emission factors across twelve databases, flags gaps, and exports with full provenance — every row sourced, DQI-scored, and ready for an auditor question.';

// §II — Audience routing (3 persona doors)
const audiences = [
  {
    label: 'For LCA consultants',
    body:
      'Your 60% is database lookup. Cortex compresses it: ask in Chinese or English, get DQI-scored candidates across HiQLCD and Ecoinvent, with every proxy assumption attached.',
    href: '/solutions/bom-matching',
    cta: 'See BOM matching',
  },
  {
    label: 'For sustainability and CBAM teams',
    body:
      "Your auditor wants the reasoning, not the number. Cortex pauses at three HITL gates — coverage, proxy, cross-db spread — so every proxy decision has a name, not a footnote.",
    href: '/methodology',
    cta: 'Read the methodology',
  },
  {
    label: 'For developers building on LCA data',
    body:
      'Four protocols: REST, MCP, AG-UI, A2A. One API key. Embed LCA retrieval in your own product without rebuilding the search layer.',
    href: 'https://docs.x.hiq.earth',
    cta: 'Read the API docs',
  },
];

// §III — Two products
const products = [
  {
    name: 'Cortex Chat',
    pitch: 'LCA data retrieval, in a conversation. Ask in Chinese or English — results come back ranked, DQI-scored, and sourced.',
    primary: { href: '/chat', label: 'Open Cortex Chat' },
    secondary: { href: '/product/chat', label: 'Product overview' },
  },
  {
    name: 'Cortex Cowork',
    pitch: 'The desktop agent that stays with your LCA project — across sessions, across restarts, across handoffs.',
    primary: { href: 'https://github.com/HiQ-AI/cortex-desktop/releases/latest', label: 'Download for macOS' },
    secondary: { href: '/product/cowork', label: 'Product overview' },
  },
];

// §IV — Snail triptych
const qualities = [
  {
    numeral: 'I',
    key: 'Slow',
    body:
      'Speed in LCA is a trap. The CBAM verifier does not want an answer — she wants the reasoning behind the answer. Cortex does not skip the system-boundary discussion to hand you a number. Slow is the discipline that keeps the output auditable.',
  },
  {
    numeral: 'II',
    key: 'Shell',
    body:
      'A snail carries everything it needs. Cortex works the same way: every dataset returned carries its source, its version, its system model, and its DQI scores — Temporal, Geographic, Technology, Completeness, Reliability. The output is not a number. It is a package you can hand to an auditor.',
  },
  {
    numeral: 'III',
    key: 'Trail',
    body:
      'A snail leaves a mark on everything it touches. Cortex keeps the full trail: which databases were searched, which candidates were ranked, which proxy was chosen and why, which gate paused the run. The auditor and the next practitioner can walk it back to the origin.',
  },
];

// §V — Trust signal (capability claims, all verifiable)
const claims = [
  {
    stat: '~10 min for a 100-row BOM',
    body: 'Each row returns DQI-scored candidates, source citations, and every proxy assumption named.',
  },
  {
    stat: 'Twelve LCA databases',
    body: 'HiQLCD, Ecoinvent, EF (Environmental Footprint), CarbonMinds, Tiangong, World Steel, and more — ranked by relevance and data quality, not alphabetically.',
  },
  {
    stat: 'Three human-in-the-loop gates',
    body: 'Cortex pauses when coverage drops below 80%, when a proxy is required, or when cross-database spread exceeds 2×. You decide at each gate. Nothing proceeds without you.',
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- ═══ Hero ═══ -->
  <section class="relative overflow-hidden">
    <div class="container-page pt-14 md:pt-20 pb-24 md:pb-32">

      <div class="rise rise-1 mb-10 flex items-baseline justify-between border-b border-rule pb-4">
        <p class="eyebrow">HiQ Cortex · A product of HiQ-AI</p>
        <p class="hidden sm:block" style="font-family: 'Newsreader Variable', serif; font-variation-settings: 'opsz' 14; font-style: italic; color: var(--ink-faint); font-size: 0.86rem;">
          Vol. 01 · On the slow answer
        </p>
        <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
      </div>

      <div class="grid gap-10 md:grid-cols-[1.25fr_1fr] md:gap-14 items-start">

        <div class="relative">
          <h1 class="rise rise-2 font-display" style="font-size: clamp(2.6rem, 6vw, 5rem); line-height: 1.05; letter-spacing: -0.025em; font-variation-settings: 'SOFT' 30, 'opsz' 144; font-weight: 400;">
            Your <em style="color: var(--shell); font-style: italic; font-variation-settings: 'SOFT' 80, 'opsz' 144;">BOM</em> has 300 rows.<br/>
            Your <span style="color: var(--ink);">auditor</span> has questions about<br/>
            <span style="color: var(--ink-faint);">all of them.</span>
          </h1>

          <p class="rise rise-3 mt-10 max-w-xl font-serif" style="font-size: 1.14rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
            Cortex matches emission factors across <strong style="color: var(--ink); font-weight: 500;">twelve databases</strong>, flags gaps, and exports with full provenance — every row sourced, DQI-scored, and ready for an auditor question.
          </p>

          <p class="rise rise-4 mt-6 max-w-xl font-serif italic" style="font-variation-settings: 'opsz' 14; color: var(--ink-faint);">
            It does not replace experts. It scales their judgment.
          </p>

          <div class="rise rise-5 mt-12 flex flex-wrap items-center gap-4">
            <a href="/solutions/bom-matching" class="ticket">See a BOM walkthrough <span aria-hidden="true">→</span></a>
            <a href="/chat" class="ticket-ghost">Try Cortex Chat</a>
          </div>
        </div>

        <aside class="relative rise rise-3 md:pt-6">
          <div class="relative flex justify-center md:justify-end" style="color: var(--ink);">
            <SnailGlyph class="w-full max-w-md" />
          </div>
          <div class="margin-note mt-6 md:mt-10 grid gap-4 sm:grid-cols-2">
            <div>
              <span class="eyebrow block mb-2">fig. 1</span>
              The snail does not skip steps. Neither does the reasoning chain.
            </div>
            <div>
              <span class="eyebrow block mb-2">fig. 2</span>
              Each row: one question. Each answer: source, version, assumption attached.
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══ §II Audience routing ═══ -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Three doors in" numeral="II" title="Cortex Chat and Cortex Cowork serve the same engine." />
      <p class="max-w-2xl font-serif" style="font-size: 1.1rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Which door depends on the work in front of you.
      </p>

      <div class="mt-14 grid gap-px overflow-hidden border border-rule md:grid-cols-3" style="background: var(--rule);">
        {audiences.map((a, i) => (
          <article class="p-8 md:p-10 flex flex-col gap-5" style="background: var(--paper);">
            <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: 1.1rem;">§ {String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 40; font-size: 1.4rem; line-height: 1.15; letter-spacing: -0.01em;">{a.label}</h3>
            <p class="font-serif" style="line-height: 1.55; font-variation-settings: 'opsz' 17; color: var(--ink); font-size: 0.98rem;">{a.body}</p>
            <a href={a.href} class="mt-auto smallcaps" style="text-decoration: none; color: var(--shell);">{a.cta} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ §III Two products ═══ -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="What it is" numeral="III" title="One Cortex. Two products." />
      <p class="max-w-2xl font-serif" style="font-size: 1.1rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Cortex Chat handles conversations — single-session questions, BOM uploads, cross-database comparison. Cortex Cowork handles projects — local files, multi-session memory, agentic execution. Same engine underneath. Different surface for different work.
      </p>

      <div class="mt-14 grid gap-px overflow-hidden border border-rule md:grid-cols-2" style="background: var(--rule);">
        {products.map((p) => (
          <article class="p-10 md:p-12 flex flex-col gap-5" style="background: var(--paper);">
            <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: clamp(1.8rem, 3vw, 2.4rem); line-height: 1.05; letter-spacing: -0.02em;">{p.name}</h3>
            <p class="font-serif" style="line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink); font-size: 1.05rem;">{p.pitch}</p>
            <div class="mt-auto flex flex-wrap items-center gap-4 pt-4">
              <a href={p.primary.href} class="ticket">{p.primary.label} <span aria-hidden="true">→</span></a>
              <a href={p.secondary.href} class="smallcaps" style="text-decoration: none; color: var(--ink-mute);">{p.secondary.label} →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ §IV Why a snail ═══ -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="Why a snail" numeral="IV" title="We picked the opposite of a rocket, on purpose." />

      <p class="max-w-3xl font-serif" style="font-size: 1.1rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Every AI company chose a lightning bolt. We chose a snail. Here is the argument.
      </p>

      <div class="mt-14 grid gap-px overflow-hidden border border-rule md:grid-cols-3" style="background: var(--rule);">
        {qualities.map((q) => (
          <article class="p-8 md:p-10 flex flex-col gap-5" style="background: var(--paper);">
            <div class="flex items-baseline justify-between">
              <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.25rem;">§ {q.numeral}</span>
              <span class="eyebrow">{q.key}</span>
            </div>
            <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.05; letter-spacing: -0.015em;">{q.key}</h3>
            <p class="font-serif" style="line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink); font-size: 0.98rem;">{q.body}</p>
          </article>
        ))}
      </div>

      <Asterism />

      <blockquote class="mx-auto max-w-3xl text-center">
        <p class="pullquote">
          Cortex does the fastest things on the backend. What it delivers is always the slowest thing:
          <em style="color: var(--shell); font-style: italic;">a chain of reasoning you can audit, line by line.</em>
        </p>
        <footer class="eyebrow mt-6">Slow is the most important promise we can make.</footer>
      </blockquote>
    </div>
  </section>

  <!-- ═══ §V Trust signal ═══ -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="What you actually get" numeral="V" title="Three claims. All provable from how Cortex works today." />

      <div class="mt-12 border-y border-rule">
        {claims.map((c, i) => (
          <article class="grid items-baseline gap-6 py-10 border-b border-rule last:border-b-0 md:grid-cols-[5rem_minmax(0,_1fr)_minmax(0,_1.4fr)] md:gap-12">
            <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: 1.6rem;">§ {String(i + 1).padStart(2, '0')}</span>
            <div class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 40; font-size: clamp(1.3rem, 2.4vw, 1.8rem); line-height: 1.1; letter-spacing: -0.015em;">{c.stat}</div>
            <p class="font-serif" style="line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink-mute); font-size: 0.98rem;">{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ §VI Closing ═══ -->
  <section class="border-t border-rule">
    <div class="container-prose py-24 text-center">
      <Asterism class="mb-10" />
      <h2 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 96; font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.02; letter-spacing: -0.02em;">
        Start with one question.
      </h2>
      <p class="mx-auto mt-8 max-w-xl font-serif italic" style="font-size: 1.12rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        Cortex Chat takes a material name, a BOM row, or a standards question and returns ranked datasets with provenance. No spreadsheet setup. No database license required to ask.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/chat" class="ticket">Try Cortex Chat <span aria-hidden="true">→</span></a>
        <a href="mailto:info@hiqlcd.com" class="ticket-ghost">Contact us</a>
      </div>
    </div>
  </section>

</BaseLayout>
