---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Asterism from '@/components/Asterism.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = 'Cortex Chat — HiQ Cortex';
const description =
  'The LCA workbench in a conversation. Ask in Chinese or English; get ranked emission factor candidates across HiQLCD, Ecoinvent, EF, CarbonMinds, and more — with DQI, source, and reasoning attached.';

const scenarios = [
  {
    numeral: 'I',
    label: 'Bulk BOM Matching',
    href: '/solutions/bom-matching',
    body:
      'Upload a Bill of Materials — Excel, CSV, or pasted. Cortex asks the one or two clarifying questions that actually matter (alloy grade, production route, region), then fans out across five databases in parallel. Every row returns with DQI-scored candidates and a clickable source. Three human-in-the-loop gates stop the agent before it silently picks.',
    proof: '~100-row BOM · ~10 min · full provenance · Excel export',
  },
  {
    numeral: 'II',
    label: 'Single Material Carbon Search',
    href: '/solutions/carbon-search',
    body:
      'Ask a question in plain Chinese or English — "冷轧钢板 CN 电弧炉 scope CBAM" — and get ranked candidates with unit and region disambiguation. Cortex surfaces the spread across databases rather than averaging silently.',
    proof: 'Multi-database · zh+en · unit-aware · top-k results',
  },
  {
    numeral: 'III',
    label: 'Cross-database comparison',
    href: '/methodology',
    body:
      'Same material, multiple databases: Ecoinvent cutoff vs. APOS, EF 3.1 vs. HiQLCD for CN-specific supply chains. Cortex explains why the numbers diverge — system model, boundary, temporal fit — not just which is bigger.',
    proof: 'DQI × 5 dimensions · system-model aware',
  },
  {
    numeral: 'IV',
    label: 'Proxy dataset selection',
    href: '/methodology',
    body:
      "When the exact material doesn't exist in any database, Cortex proposes proxies explicitly — what's being substituted, which axis differs (region / process / DQI), what the delta implies. You confirm or replace; it never proxies silently.",
    proof: 'Named proxy · stated delta · auditable substitution',
  },
];

const surfaces = [
  { name: 'Web',           body: 'cortex.hiq.earth/chat — nothing to install.',                          tag: 'live' },
  { name: 'API',           body: 'REST · MCP · AG-UI · A2A. Embed Cortex in your own tool.',            tag: 'beta' },
  { name: 'DingTalk Bot',  body: '"Cuisi" (翠丝) — Cortex answers in your group chat.',                 tag: 'live' },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="relative">
    <div class="container-page pt-14 md:pt-20 pb-14">
      <div class="mb-10 flex items-baseline justify-between border-b border-rule pb-4">
        <p class="eyebrow">Product · Cortex Chat</p>
        <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
      </div>
      <h1 class="font-display" style="font-size: clamp(2.4rem, 6vw, 5rem); line-height: 1; letter-spacing: -0.025em; font-variation-settings: 'SOFT' 40, 'opsz' 144; font-weight: 400; max-width: 18ch;">
        The LCA workbench, <em style="color: var(--shell); font-style: italic; font-variation-settings: 'SOFT' 80;">in a conversation</em>.
      </h1>
      <p class="mt-10 max-w-2xl font-serif" style="font-size: 1.2rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Ask Cortex the question you'd otherwise spend the next hour typing into five database tabs.
        Get back ranked candidates, DQI scores, cited sources, and — when it matters — a clarifying
        question before any number is picked.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/chat" class="ticket">Open Cortex Chat <span aria-hidden="true">→</span></a>
        <a href="/solutions/bom-matching" class="ticket-ghost">See a BOM walkthrough</a>
      </div>
    </div>
  </section>

  <!-- Where it runs -->
  <section class="border-t border-rule">
    <div class="container-page py-14 md:py-16">
      <div class="eyebrow mb-6">Where Cortex Chat runs</div>
      <div class="grid gap-px overflow-hidden border border-rule md:grid-cols-3" style="background: var(--rule);">
        {surfaces.map((s) => (
          <div class="flex items-baseline gap-4 p-6" style="background: var(--paper);">
            <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: 1.1rem;">§</span>
            <div>
              <div class="flex items-baseline gap-3">
                <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.15rem;">{s.name}</h3>
                <span class="font-mono uppercase" style="font-size: 0.65rem; letter-spacing: 0.14em; color: var(--shell);">{s.tag}</span>
              </div>
              <p class="mt-2 font-serif" style="font-size: 0.95rem; line-height: 1.5; font-variation-settings: 'opsz' 14; color: var(--ink-mute);">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Scenarios -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="What people use it for" numeral="I–IV" title="Four scenarios, one cortex." />

      <p class="max-w-3xl font-serif" style="font-size: 1.12rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
        These are the conversations Chat was built for. Everything below happens in one tab,
        against curated LCA databases, with the same reasoning discipline.
      </p>

      <div class="mt-14 border-y border-rule">
        {scenarios.map((s) => (
          <article class="border-b border-rule last:border-b-0">
            <div class="grid items-baseline gap-6 py-10 md:grid-cols-[4rem_1fr_auto] md:gap-10">
              <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: clamp(1.6rem, 2.5vw, 2rem);">§ {s.numeral}</span>
              <div>
                <h3 class="font-display mb-3" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: clamp(1.5rem, 2.8vw, 2.1rem); line-height: 1.1; letter-spacing: -0.015em; color: var(--ink);">{s.label}</h3>
                <p class="font-serif max-w-2xl" style="line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink);">{s.body}</p>
                <p class="mt-4 font-mono" style="font-size: 0.72rem; letter-spacing: 0.06em; color: var(--ink-faint);">{s.proof}</p>
              </div>
              <a href={s.href} class="smallcaps" aria-hidden="true" style="text-decoration: none; color: var(--ink-mute); white-space: nowrap;">Read →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Pull quote / slow/shell/trail brief mention -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <Asterism class="mb-12" />
      <blockquote class="mx-auto max-w-3xl text-center">
        <p class="pullquote">
          Chat returns top-<em style="color: var(--shell); font-style: italic;">k</em>, not top-1.
          Every candidate carries its source, its region, its system model, and its DQI.
        </p>
        <footer class="eyebrow mt-6">The reasoning chain is part of the deliverable.</footer>
      </blockquote>
    </div>
  </section>

  <!-- Chat vs Cowork -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Which Cortex" numeral="V" title="Chat is the web surface. Cowork is the desktop one." />
      <div class="grid gap-px overflow-hidden border border-rule md:grid-cols-2" style="background: var(--rule);">
        <div class="p-8 md:p-10" style="background: var(--paper);">
          <div class="eyebrow mb-3" style="color: var(--shell);">Cortex Chat</div>
          <h3 class="font-display mb-3" style="font-variation-settings: 'SOFT' 40, 'opsz' 40; font-size: 1.5rem;">One tab. One question.</h3>
          <p class="font-serif" style="line-height: 1.55; font-variation-settings: 'opsz' 18; color: var(--ink);">
            Best when the question fits in a session: a single BOM, a material lookup, a cross-database check.
            Nothing to install. Excel in, Excel out.
          </p>
          <a href="/chat" class="mt-6 inline-block smallcaps" style="color: var(--shell);">Open Chat →</a>
        </div>
        <div class="p-8 md:p-10" style="background: var(--paper);">
          <div class="eyebrow mb-3">Cortex Cowork</div>
          <h3 class="font-display mb-3" style="font-variation-settings: 'SOFT' 40, 'opsz' 40; font-size: 1.5rem;">Projects that outlive a session.</h3>
          <p class="font-serif" style="line-height: 1.55; font-variation-settings: 'opsz' 18; color: var(--ink);">
            Best when the project spans weeks: multiple BOMs, iterative queries, local files,
            team handoff. The agent remembers; the workbench persists.
          </p>
          <a href="/product/cowork" class="mt-6 inline-block smallcaps" style="color: var(--ink-mute);">Meet Cowork →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="border-t border-rule">
    <div class="container-prose py-24 text-center">
      <h2 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 96; font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.02; letter-spacing: -0.02em;">
        One material. One BOM. One conversation.
      </h2>
      <p class="mx-auto mt-8 max-w-xl font-serif italic" style="font-size: 1.1rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        Start with whatever question is on your desk. Cortex Chat answers — and shows its work.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/chat" class="ticket">Open Cortex Chat</a>
        <a href="/methodology" class="ticket-ghost">Read the methodology</a>
      </div>
    </div>
  </section>
</BaseLayout>
