---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Asterism from '@/components/Asterism.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = 'Cortex Cowork — HiQ Cortex';
const description =
  'The desktop agent that stays with your LCA project. Cowork runs on your machine, reads your files, and carries decisions across sessions and restarts.';

const platforms = [
  { name: 'macOS',   detail: 'Apple Silicon (M1–M4) and Intel · .dmg', note: 'Gatekeeper: System Settings → Privacy & Security → Open Anyway on first launch.' },
  { name: 'Windows', detail: '.exe installer',                          note: null },
  { name: 'Linux',   detail: '.AppImage or .deb (dpkg -i)',            note: null },
];

const scenarios = [
  {
    numeral: 'I',
    label: 'BOM processing',
    before: 'Open Excel + query databases one by one + log results manually.',
    after:  'Upload the BOM. Cortex identifies materials, runs cross-database matching, and fills in missing datasets — row by row, with every match sourced.',
    detail: 'Cortex reads your BOM file directly from disk. It searches HiQLCD, Ecoinvent, EF, and the rest of the twelve-database surface in parallel per row, flags rows where coverage is below threshold, and writes the matched GWP100 values back into a new Excel file. No copy-paste. No tab-switching.',
    proof:  'BOM.xlsx → parallel search → matched GWP100 · source · DQI per row',
  },
  {
    numeral: 'II',
    label: 'Scope 3 calculation',
    before: 'Consult GHG Protocol documentation + ask an AI separately + classify categories by hand.',
    after:  'Provide the activity data file. Cortex classifies categories automatically, builds the data-collection checklist, and runs the calculation.',
    detail: 'All 15 GHG Protocol Scope 3 categories are supported. Cortex handles upstream, downstream, and use-phase classifications — Category 1 (Purchased goods and services) at the BOM-row level, the rest with factor identification and data-collection checklists. The output is a calculation file with category totals and factor sources, not a black-box number.',
    proof:  'Activity data in → 15 categories · factor matching · calculation out',
  },
  {
    numeral: 'III',
    label: 'openLCA operation',
    before: 'Learn the openLCA interface + build flows by hand + read the documentation.',
    after:  'Describe what you need. Cortex connects to openLCA, matches background datasets, builds the product system, and runs the calculation.',
    detail: "Cortex does not replace openLCA — it drives it. Start openLCA's IPC server, point Cowork at your BOM file, and describe the goal in plain language. Cortex handles the dataset matching, system construction, circular-reference resolution, and result export. Your openLCA instance is the model; Cortex is the operator.",
    proof:  'openLCA → dataset match → product system built → results exported',
  },
  {
    numeral: 'IV',
    label: 'EPD report generation',
    before: 'Find the template + copy data out of the LCA software + fill in Word by hand.',
    after:  'One request. Cortex pulls from the calculation results and produces a structured .docx file following EPD standard layout.',
    detail: 'Cortex pulls declared unit, system boundary, reference flows, and LCIA results from the calculation — and formats them into a .docx file following EPD standard structure. The Product Category Rule (PCR) selection and third-party verification remain the practitioner\'s step. No reformatting. No re-entry.',
    proof:  'Calculation results → EPD layout applied → .docx out · PCR practitioner-led',
  },
];

const compare = [
  ['Session history',         'Cloud-synced',                          'Local only'],
  ['File access',             'No local files',                        'Full read/write'],
  ['Script execution',        'Not available',                         'Local execution'],
  ['Skills system',           'Limited',                               'Full skills marketplace + custom MCP'],
  ['LCA database search',     'Yes',                                   'Yes'],
  ['Best for',                'Quick queries, methodology Q&A',        'BOM matching, report generation, project work'],
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="relative">
    <div class="container-page pt-14 md:pt-20 pb-14">
      <div class="mb-10 flex items-baseline justify-between border-b border-rule pb-4">
        <p class="eyebrow">Product · Cortex Cowork</p>
        <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
      </div>
      <h1 class="font-display" style="font-size: clamp(2.4rem, 6vw, 5rem); line-height: 1.02; letter-spacing: -0.025em; font-variation-settings: 'SOFT' 40, 'opsz' 144; font-weight: 400; max-width: 20ch;">
        The desktop agent that <em style="color: var(--shell); font-style: italic; font-variation-settings: 'SOFT' 80;">stays with</em> your LCA project.
      </h1>
      <p class="mt-10 max-w-2xl font-serif" style="font-size: 1.18rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink);">
        LCA work doesn't fit in one conversation. Cowork runs on your machine, reads your files, and carries the boundary decisions, the proxy log, and the supplier data — across sessions, across restarts.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="https://github.com/HiQ-AI/cortex-desktop/releases/latest" class="ticket">Download Cortex Desktop <span aria-hidden="true">→</span></a>
        <a href="#scenarios" class="ticket-ghost">See what it handles</a>
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="border-t border-rule">
    <div class="container-page py-14 md:py-16">
      <div class="eyebrow mb-3">Available on your machine</div>
      <p class="max-w-2xl font-serif italic" style="font-size: 0.95rem; line-height: 1.55; font-variation-settings: 'opsz' 16; color: var(--ink-mute);">
        No login required to install. Login required to sync cloud services and run database searches.
      </p>
      <div class="mt-8 grid gap-px overflow-hidden border border-rule md:grid-cols-3" style="background: var(--rule);">
        {platforms.map((p) => (
          <div class="p-6" style="background: var(--paper);">
            <div class="flex items-baseline justify-between mb-2">
              <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.2rem;">{p.name}</h3>
              <span class="font-mono uppercase" style="font-size: 0.62rem; letter-spacing: 0.14em; color: var(--shell);">live</span>
            </div>
            <p class="font-mono" style="font-size: 0.78rem; letter-spacing: 0.04em; color: var(--ink-mute);">{p.detail}</p>
            {p.note && <p class="mt-3 font-serif italic" style="font-size: 0.85rem; line-height: 1.5; font-variation-settings: 'opsz' 14; color: var(--ink-faint);">{p.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Scenarios -->
  <section id="scenarios" class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-28">
      <SectionMark kicker="What it's good for" numeral="I–IV" title="Four workflows Chat can't run." />
      <p class="max-w-3xl font-serif" style="font-size: 1.1rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Cowork operates on your files, executes tools locally, and picks up where the last session ended. These four workflows show what that means in practice.
      </p>

      <div class="mt-14 border-y border-rule">
        {scenarios.map((s) => (
          <article class="border-b border-rule last:border-b-0 py-12">
            <div class="grid items-start gap-6 md:grid-cols-[4rem_minmax(0,_1fr)] md:gap-10">
              <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: clamp(1.5rem, 2.4vw, 1.9rem);">§ {s.numeral}</span>
              <div>
                <h3 class="font-display mb-5" style="font-variation-settings: 'SOFT' 40, 'opsz' 60; font-size: clamp(1.5rem, 2.6vw, 2.1rem); line-height: 1.1; letter-spacing: -0.015em; color: var(--ink);">{s.label}</h3>

                <div class="grid gap-4 mb-6 md:grid-cols-[5rem_minmax(0,_1fr)] md:gap-6 max-w-3xl">
                  <span class="eyebrow" style="color: var(--ink-faint);">Before</span>
                  <p class="font-serif" style="line-height: 1.55; font-variation-settings: 'opsz' 16; color: var(--ink-mute); font-size: 0.95rem;">{s.before}</p>
                  <span class="eyebrow" style="color: var(--shell);">After</span>
                  <p class="font-serif" style="line-height: 1.55; font-variation-settings: 'opsz' 16; color: var(--ink); font-size: 0.95rem; font-weight: 500;">{s.after}</p>
                </div>

                <p class="font-serif max-w-3xl" style="line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink); font-size: 1rem;">{s.detail}</p>
                <p class="mt-4 font-mono" style="font-size: 0.72rem; letter-spacing: 0.06em; color: var(--ink-faint);">{s.proof}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Reasoning chain -->
  <section class="border-t border-rule">
    <div class="container-page py-16 md:py-20">
      <div class="eyebrow mb-3">The same rigor. Your files.</div>
      <p class="max-w-3xl font-serif" style="font-size: 1.1rem; line-height: 1.65; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Cowork inherits Cortex's core reasoning rules: top-k candidates ranked by DQI, three human-in-the-loop gates (coverage below 80%, proxy required, cross-database spread exceeds 2×), and every assumption named. In Cowork, those gates fire inside a multi-step session, and decisions accumulate across days.
      </p>
      <p class="mt-6">
        <a href="/standards" class="smallcaps" style="color: var(--shell);">Standards alignment →</a>
      </p>
    </div>
  </section>

  <!-- Chat vs Cowork -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Which Cortex" numeral="V" title="When to use Cowork instead of Chat." />

      <p class="mt-10 max-w-3xl font-display italic" style="font-variation-settings: 'SOFT' 60, 'opsz' 36; font-size: clamp(1.4rem, 2.6vw, 1.8rem); line-height: 1.3; color: var(--ink);">
        Cortex Chat answers questions. Cortex Cowork runs workflows — on your machine, in your project folder, across as many sessions as the work takes.
      </p>

      <div class="mt-10 overflow-hidden rounded-sm border border-rule" style="background: var(--paper);">
        <table class="w-full" style="border-collapse: collapse;">
          <thead>
            <tr style="background: var(--paper-rim);">
              <th class="eyebrow text-left p-4 border-b border-rule"></th>
              <th class="eyebrow text-left p-4 border-b border-rule">Cortex Chat</th>
              <th class="eyebrow text-left p-4 border-b border-rule" style="color: var(--shell);">Cortex Cowork</th>
            </tr>
          </thead>
          <tbody class="font-serif" style="font-size: 0.94rem; line-height: 1.5; font-variation-settings: 'opsz' 16;">
            {compare.map(([label, chat, cowork]) => (
              <tr>
                <td class="p-4 border-b border-rule" style="color: var(--ink-mute); font-weight: 500;">{label}</td>
                <td class="p-4 border-b border-rule" style="color: var(--ink-mute);">{chat}</td>
                <td class="p-4 border-b border-rule" style="color: var(--ink);">{cowork}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-8">
        <a href="/product/chat" class="smallcaps" style="color: var(--ink-mute);">Meet Cortex Chat →</a>
      </p>
    </div>
  </section>

  <!-- Closer -->
  <section class="border-t border-rule">
    <div class="container-prose py-24 text-center">
      <Asterism class="mb-10" />
      <h2 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 96; font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.02; letter-spacing: -0.02em;">
        Install once. Pick up where you left off.
      </h2>
      <p class="mx-auto mt-8 max-w-xl font-serif italic" style="font-size: 1.1rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        Cowork keeps the project context between restarts: the decisions made, the proxy choices logged, the rows already matched. The next session starts where the last one ended.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="https://github.com/HiQ-AI/cortex-desktop/releases/latest" class="ticket">Download Cortex Desktop <span aria-hidden="true">→</span></a>
        <a href="mailto:info@hiqlcd.com" class="ticket-ghost">Questions · info@hiqlcd.com</a>
      </div>
    </div>
  </section>
</BaseLayout>
