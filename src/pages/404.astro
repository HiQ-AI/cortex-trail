---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Asterism from '@/components/Asterism.astro';

const title = 'Not found — HiQ Cortex';
const description = 'This page has wandered off its trail.';
---

<BaseLayout title={title} description={description}>
  <section class="container-prose py-32 text-center">
    <p class="eyebrow" style="color: var(--shell);">404</p>
    <h1 class="font-display mt-6" style="font-variation-settings: 'SOFT' 40, 'opsz' 96; font-size: clamp(2.4rem, 5vw, 4rem); line-height: 1.02; letter-spacing: -0.02em;">
      Off the trail.
    </h1>
    <p class="mt-8 font-serif italic" style="font-size: 1.15rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
      The snail carries its shell, but this page seems to have left without one.
    </p>
    <Asterism class="mt-10" />
    <a href="/" class="ticket">Back to home</a>
  </section>
</BaseLayout>
