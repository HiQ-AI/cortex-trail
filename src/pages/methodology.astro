---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Asterism from '@/components/Asterism.astro';
import SectionMark from '@/components/SectionMark.astro';

const title = 'Methodology — HiQ Cortex';
const description =
  'How HiQ Cortex produces audit-grade LCA answers: data sources, DQI scoring, proxy strategy, human-in-the-loop gates, and standards alignment.';

const principles = [
  {
    heading: 'Numbers come from tools, not from the model.',
    body:
      'GWP values, DQI scores, and dataset descriptions come from curated databases. The LLM handles question parsing, candidate ranking, and explanation — not emission factor generation.',
  },
  {
    heading: 'Domain knowledge informs commentary, not data.',
    body:
      'When Cortex says "1040 is typically for automotive leaf springs", that is commentary. When Cortex says the factor is 2.31 kgCO₂e/kg, that comes from a cited, clickable dataset row.',
  },
  {
    heading: 'Restricted rows stay restricted.',
    body:
      'For licensed datasets the user hasn\'t accessed, Cortex returns a truthful "⛔ no access" marker — not a substituted literature value passed off as data.',
  },
  {
    heading: 'A chain of reasoning is part of the deliverable.',
    body:
      'Every Excel export ships with match type, proxy notes, and source URLs. A downstream reviewer can reproduce or challenge any cell without re-running the system.',
  },
];

const sources = [
  { name: 'HiQLCD',                      coverage: 'China-focused primary data; materials, processes, supply-chain proxies' },
  { name: 'Ecoinvent',                   coverage: 'Global LCI, cut-off + APOS system models' },
  { name: 'EF (Environmental Footprint)', coverage: 'EU-authorized datasets for PEF and CBAM scope' },
  { name: 'CarbonMinds',                 coverage: 'Chemicals and polymers, process-specific' },
  { name: 'Industry secondaries',        coverage: 'Supplier-issued EPDs and verified PCFs, on request' },
];

const dqi = [
  { label: 'Temporal',     body: "Is the dataset's reference year within the target window?" },
  { label: 'Geographic',   body: 'Does the region match the BOM row, or is it a reasonable proxy?' },
  { label: 'Technology',   body: 'Does the production route match — BF-BOF vs. EAF, virgin vs. recycled?' },
  { label: 'Completeness', body: 'Are the upstream cradle-to-gate steps modeled, or scoped out?' },
  { label: 'Reliability',  body: 'Source type: measured, calculated, expert estimate, or literature.' },
];

const gates = [
  {
    trigger: 'Coverage below 80%',
    action: 'Cortex pauses and lists unmatched rows with candidate datasets. The user picks: expand databases, accept a proxy, or defer.',
  },
  {
    trigger: 'Proxy substitution required',
    action: 'Cortex names the proxy explicitly — which dataset, what differs (region / process / DQI), what the delta implies. The user confirms or replaces.',
  },
  {
    trigger: 'Cross-database disagreement > 2×',
    action: 'When the same material returns factors that differ by more than 2× across databases, Cortex surfaces the spread rather than averaging silently.',
  },
];

const standards = [
  { code: 'ISO 14067',   note: 'Carbon footprint of products — boundary, allocation, reporting' },
  { code: 'ISO 14044',   note: 'LCA requirements and guidelines — the common substrate for tooling and auditors' },
  { code: 'GHG Protocol', note: 'Product Life Cycle Accounting and Reporting Standard' },
  { code: 'PEF / EF 3.1', note: 'EU Product Environmental Footprint method and EF datasets' },
  { code: 'CBAM',         note: 'Emission factor selection for embedded-emissions reporting' },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="relative">
    <div class="container-page pt-14 md:pt-20 pb-14">
      <div class="mb-10 flex items-baseline justify-between border-b border-rule pb-4">
        <p class="eyebrow">Methodology</p>
        <p class="running-footer">{new Date().toISOString().slice(0, 10)}</p>
      </div>
      <h1 class="font-display" style="font-size: clamp(2.2rem, 5.5vw, 4.5rem); line-height: 1.03; letter-spacing: -0.02em; font-variation-settings: 'SOFT' 40, 'opsz' 144; font-weight: 400; max-width: 20ch;">
        How Cortex produces an answer you can defend.
      </h1>
      <p class="mt-10 max-w-2xl font-serif italic" style="font-size: 1.18rem; line-height: 1.55; font-variation-settings: 'opsz' 20; color: var(--ink-mute);">
        For reviewers, auditors, and procurement teams who need to understand what Cortex does
        before they trust a number it produced.
      </p>
    </div>
  </section>

  <!-- Principles -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Section" numeral="I" title="Principles" />
      <div class="grid gap-10 md:grid-cols-2">
        {principles.map((p, i) => (
          <article class="relative pl-8 border-l border-rule">
            <span class="absolute -left-[1px] top-0 font-display italic" style="background: var(--paper); color: var(--shell); padding: 0 0.4rem 0 0; transform: translateX(-50%); font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 0.95rem;">§{i + 1}</span>
            <h3 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 40; font-size: 1.3rem; line-height: 1.15; letter-spacing: -0.01em;">{p.heading}</h3>
            <p class="mt-3 font-serif" style="line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink);">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Data sources -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Section" numeral="II" title="Data sources" />
      <p class="max-w-2xl font-serif" style="font-size: 1.08rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Cortex searches twelve curated LCI and LCA databases, each indexed with its own unit, region,
        and system-model vocabulary. Nothing is merged blindly. The five named below are the most
        frequently cited; the remainder are queried in parallel and surfaced when their datasets
        rank against the BOM row.
      </p>
      <div class="mt-10">
        {sources.map((s, i) => (
          <div class="row-line">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <div class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.05rem; letter-spacing: -0.01em;">{s.name}</div>
              <div class="mt-1 font-serif italic" style="font-variation-settings: 'opsz' 14; color: var(--ink-faint); font-size: 0.92rem;">{s.coverage}</div>
            </div>
            <span class="font-mono" style="font-size: 0.7rem; color: var(--ink-whisper); letter-spacing: 0.06em;">source</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DQI -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Section" numeral="III" title="Data Quality Indicator (DQI)" />
      <p class="max-w-2xl font-serif" style="font-size: 1.08rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Cortex uses DQI as its single confidence vocabulary because it's what reviewers already
        speak. A low score on any axis appears in the export — not hidden inside a probability
        number.
      </p>
      <div class="mt-10 grid gap-px overflow-hidden border border-rule md:grid-cols-5" style="background: var(--rule);">
        {dqi.map((d, i) => (
          <div class="p-6 flex flex-col gap-3" style="background: var(--paper);">
            <div class="flex items-baseline justify-between">
              <span class="font-display italic" style="color: var(--shell); font-variation-settings: 'SOFT' 40; font-size: 1rem;">§ {i + 1}</span>
              <span class="eyebrow">axis</span>
            </div>
            <h4 class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.05rem; letter-spacing: -0.005em;">{d.label}</h4>
            <p class="font-serif" style="font-size: 0.9rem; line-height: 1.5; font-variation-settings: 'opsz' 14; color: var(--ink-mute);">{d.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HITL gates -->
  <section class="border-t border-rule" style="background: var(--paper-rim);">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Section" numeral="IV" title="Human-in-the-loop gates" />
      <p class="max-w-2xl font-serif" style="font-size: 1.08rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Three conditions are hard-wired to pause the agent and return control to the user.
        These are the moments where silent automation would break an audit.
      </p>
      <div class="mt-10 space-y-4">
        {gates.map((g, i) => (
          <article class="grid gap-6 border border-rule p-6 md:grid-cols-[10rem_1fr] md:p-8" style="background: var(--paper);">
            <div class="border-b border-rule pb-4 md:border-b-0 md:border-r md:pb-0">
              <div class="eyebrow mb-2" style="color: var(--shell);">Trigger {String(i + 1).padStart(2, '0')}</div>
              <p class="font-display" style="font-variation-settings: 'SOFT' 40, 'opsz' 24; font-size: 1.05rem; line-height: 1.2; letter-spacing: -0.01em;">{g.trigger}</p>
            </div>
            <p class="font-serif" style="line-height: 1.6; font-variation-settings: 'opsz' 18; color: var(--ink);">{g.action}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Standards -->
  <section class="border-t border-rule">
    <div class="container-page py-20 md:py-24">
      <SectionMark kicker="Section" numeral="V" title="Standards alignment" />
      <p class="max-w-2xl font-serif" style="font-size: 1.08rem; line-height: 1.6; font-variation-settings: 'opsz' 20; color: var(--ink);">
        Cortex is designed to produce outputs compatible with the standards below. Formal
        certification against a specific standard is scope-dependent and available on request.
      </p>
      <div class="mt-10">
        {standards.map((s) => (
          <div class="row-line" style="grid-template-columns: 10rem 1fr auto;">
            <span class="font-mono" style="color: var(--shell); font-size: 0.88rem; letter-spacing: 0.02em;">{s.code}</span>
            <span class="font-serif" style="font-variation-settings: 'opsz' 18; color: var(--ink);">{s.note}</span>
            <span class="font-mono" style="font-size: 0.7rem; color: var(--ink-whisper); letter-spacing: 0.06em;">std.</span>
          </div>
        ))}
      </div>
      <p class="mt-10 font-serif italic" style="font-size: 0.92rem; font-variation-settings: 'opsz' 14; color: var(--ink-faint);">
        Last reviewed: {new Date().toISOString().slice(0, 10)}. Updates tracked in the{' '}
        <a href="/changelog">changelog</a>.
      </p>
    </div>
  </section>

</BaseLayout>
