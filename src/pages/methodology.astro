---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Methodology — HiQ Cortex';
const description =
  'How HiQ Cortex produces audit-grade LCA answers: data sources, DQI scoring, proxy strategy, human-in-the-loop gates, and standards alignment.';

const principles = [
  {
    heading: 'Numbers come from tools, not from the model.',
    body:
      'GWP values, DQI scores, and dataset descriptions are retrieved from curated databases. The LLM is used for question parsing, candidate ranking, and explanation — never to invent an emission factor.',
  },
  {
    heading: 'Domain knowledge informs commentary, not data.',
    body:
      'When Cortex says "1040 is typically for automotive leaf springs", that is commentary. When Cortex says the factor is 2.31 kgCO₂e/kg, that comes from a cited, clickable dataset row.',
  },
  {
    heading: 'Restricted rows stay restricted.',
    body:
      'For licensed datasets the user has no access to, Cortex returns a truthful "⛔ no access" marker — never a substituted literature value.',
  },
  {
    heading: 'A chain of reasoning is part of the deliverable.',
    body:
      'Every Excel export ships with match type, proxy notes, and source URLs. A downstream reviewer should be able to reproduce or challenge any cell without re-running the system.',
  },
];

const sources = [
  { name: 'HiQLCD', coverage: 'China-focused primary data, 800k+ unit processes' },
  { name: 'Ecoinvent', coverage: 'Global LCI, cutoff + APOS system models' },
  { name: 'EF (Environmental Footprint)', coverage: 'EU-authorized datasets for PEF/CBAM scope' },
  { name: 'CarbonMinds', coverage: 'Chemicals and polymers, process-specific' },
  { name: 'Industry secondaries', coverage: 'Supplier-issued EPDs and verified PCFs, on request' },
];

const dqi = [
  { label: 'Temporal', body: 'Is the dataset reference year within the target window?' },
  { label: 'Geographic', body: 'Does the region match the BOM row, or is it a reasonable proxy?' },
  { label: 'Technology', body: 'Does the production route match — BF-BOF vs EAF, virgin vs recycled?' },
  { label: 'Completeness', body: 'Are the upstream cradle-to-gate steps modeled, or scoped out?' },
  { label: 'Reliability', body: 'Source type — measured, calculated, expert estimate, literature.' },
];

const gates = [
  {
    trigger: 'Coverage below 80%',
    action:
      'Cortex pauses the automation and lists unmatched rows with candidate datasets. The user picks whether to expand databases, accept a proxy, or defer.',
  },
  {
    trigger: 'Proxy substitution required',
    action:
      'Cortex names the proxy explicitly — which dataset, what differs (region / process / DQI), what the delta implies. User confirms or replaces.',
  },
  {
    trigger: 'Cross-database disagreement > 2×',
    action:
      'When the same material returns factors that differ by more than 2× across databases, Cortex surfaces the comparison rather than averaging silently.',
  },
];

const standards = [
  { code: 'ISO 14067', note: 'Carbon footprint of products — boundary, allocation, reporting' },
  { code: 'ISO 14044', note: 'LCA requirements and guidelines — the substrate both tooling and auditors share' },
  { code: 'GHG Protocol', note: 'Product Life Cycle Accounting and Reporting Standard' },
  { code: 'PEF / EF 3.1', note: 'EU Product Environmental Footprint method and EF datasets' },
  { code: 'CBAM', note: 'Emission factor selection for embedded-emissions reporting' },
];
---

<BaseLayout title={title} description={description}>
  <section class="container-wide pt-20 pb-12">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-shell-700 dark:text-shell-400">
      Methodology
    </p>
    <h1 class="heading-display mt-6 max-w-4xl text-4xl leading-[1.1] md:text-5xl">
      How Cortex produces an answer you can defend.
    </h1>
    <p class="mt-8 max-w-3xl font-serif text-lg italic text-stone-700 dark:text-stone-300">
      This page is the source of truth for reviewers, auditors, and procurement teams
      who need to understand what Cortex does before they trust a number that came out
      of it.
    </p>
  </section>

  <section class="container-wide pb-16">
    <h2 class="heading-display text-2xl md:text-3xl">Principles</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {principles.map((p) => (
        <div class="rounded-lg border border-stone-200 p-6 dark:border-stone-800">
          <h3 class="font-sans text-base font-semibold">{p.heading}</h3>
          <p class="mt-3 text-sm leading-relaxed text-stone-700 dark:text-stone-300">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-stone-200/70 py-16 dark:border-stone-800/70">
    <div class="container-wide">
      <h2 class="heading-display text-2xl md:text-3xl">Data sources</h2>
      <p class="mt-4 max-w-2xl text-stone-700 dark:text-stone-300">
        Cortex searches across curated LCI and LCA databases, each indexed with its own
        unit, region, and system-model vocabulary. Nothing is merged blindly.
      </p>
      <div class="mt-8 overflow-hidden rounded-lg border border-stone-200 dark:border-stone-800">
        <table class="w-full text-sm">
          <thead class="bg-stone-50 dark:bg-stone-900">
            <tr>
              <th class="px-6 py-3 text-left font-mono text-[11px] uppercase tracking-[0.18em] text-quiet">Source</th>
              <th class="px-6 py-3 text-left font-mono text-[11px] uppercase tracking-[0.18em] text-quiet">Coverage</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-200 dark:divide-stone-800">
            {sources.map((s) => (
              <tr>
                <td class="px-6 py-4 font-medium">{s.name}</td>
                <td class="px-6 py-4 text-stone-700 dark:text-stone-300">{s.coverage}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="border-t border-stone-200/70 py-16 dark:border-stone-800/70">
    <div class="container-wide">
      <h2 class="heading-display text-2xl md:text-3xl">Data Quality Indicator (DQI)</h2>
      <p class="mt-4 max-w-2xl text-stone-700 dark:text-stone-300">
        Cortex uses DQI as its single confidence vocabulary because it's the one reviewers
        already speak. A low DQI on any axis is surfaced in the export, not hidden in a
        probability score.
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-5">
        {dqi.map((d) => (
          <div class="rounded-lg border border-stone-200 p-4 dark:border-stone-800">
            <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-shell-700 dark:text-shell-400">{d.label}</p>
            <p class="mt-2 text-xs leading-relaxed text-stone-700 dark:text-stone-300">{d.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-stone-200/70 py-16 dark:border-stone-800/70">
    <div class="container-wide">
      <h2 class="heading-display text-2xl md:text-3xl">Human-in-the-loop gates</h2>
      <p class="mt-4 max-w-2xl text-stone-700 dark:text-stone-300">
        Three conditions are hard-wired to pause the agent and hand control to the user.
        These are the moments where silent automation would break an audit.
      </p>
      <div class="mt-8 space-y-4">
        {gates.map((g) => (
          <div class="rounded-lg border border-stone-200 p-6 dark:border-stone-800">
            <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-shell-700 dark:text-shell-400">
              Trigger
            </p>
            <p class="mt-1 font-semibold">{g.trigger}</p>
            <p class="mt-3 text-sm leading-relaxed text-stone-700 dark:text-stone-300">{g.action}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-stone-200/70 py-16 dark:border-stone-800/70">
    <div class="container-wide">
      <h2 class="heading-display text-2xl md:text-3xl">Standards alignment</h2>
      <p class="mt-4 max-w-2xl text-stone-700 dark:text-stone-300">
        Cortex is designed to produce outputs compatible with the standards below.
        Formal certification against any specific standard is scope-specific and
        available on request.
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {standards.map((s) => (
          <div class="flex items-start gap-4 rounded-lg border border-stone-200 p-5 dark:border-stone-800">
            <p class="w-28 shrink-0 font-mono text-sm text-shell-700 dark:text-shell-400">{s.code}</p>
            <p class="text-sm text-stone-700 dark:text-stone-300">{s.note}</p>
          </div>
        ))}
      </div>
      <p class="mt-10 font-serif text-sm italic text-quiet">
        Last reviewed: {new Date().toISOString().slice(0, 10)}.
        Updates to this page are tracked in the{' '}
        <a class="underline hover:text-shell-700 dark:hover:text-shell-300" href="/changelog">changelog</a>.
      </p>
    </div>
  </section>
</BaseLayout>
