---
import ThemeToggle from './ThemeToggle.astro';

interface Props { locale?: 'en' | 'zh' }
const { locale = 'en' } = Astro.props;

const nav = locale === 'zh'
  ? [
      { href: '/zh',                label: '概览' },
      { href: '/zh/product/chat',   label: 'Chat' },
      { href: '/zh/product/cowork', label: 'Cowork' },
      { href: '/zh/skills',         label: '技能库' },
      { href: '/zh/pricing',        label: '定价' },
      { href: '/zh/blog',           label: '博客' },
    ]
  : [
      { href: '/',               label: 'Overview' },
      { href: '/product/chat',   label: 'Chat' },
      { href: '/product/cowork', label: 'Cowork' },
      { href: '/skills',         label: 'Skills' },
      { href: '/pricing',        label: 'Pricing' },
      { href: '/blog',           label: 'Blog' },
    ];

const home = locale === 'zh' ? '/zh' : '/';
const chatLabel = locale === 'zh' ? '打开 Chat' : 'Open Chat';

// Compute the current page's counterpart in the other locale.
// Strip trailing slash and any /index suffix; map between /zh/* and /*.
const rawPath = Astro.url.pathname.replace(/\/$/, '') || '/';
let counterpart: string;
if (locale === 'zh') {
  // /zh/foo → /foo;  /zh → /
  counterpart = rawPath === '/zh' ? '/' : rawPath.replace(/^\/zh/, '');
} else {
  // /foo → /zh/foo;  / → /zh
  counterpart = rawPath === '/' ? '/zh' : '/zh' + rawPath;
}
const otherLocale = locale === 'zh'
  ? { href: counterpart, label: 'EN' }
  : { href: counterpart, label: '中文' };
---

<header class="relative z-20 border-b border-rule">
  <div class="container-page flex h-16 items-center justify-between">
    <a href={home} class="group flex items-center gap-3 no-underline" style="text-decoration: none;" aria-label="HiQ Cortex home">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--ink);">
        <path d="M2 13a6 6 0 1 0 12 0 4 4 0 1 0-8 0 2 2 0 0 0 4 0"/>
        <circle cx="10" cy="13" r="8"/>
        <path d="M2 21h12c4.4 0 8-3.6 8-8V7a2 2 0 1 0-4 0v6"/>
        <path d="M18 3 19.1 5.2"/>
        <path d="M22 3 20.9 5.2"/>
      </svg>
      <span class="font-display text-[1.08rem] font-medium tracking-tight" style="font-variation-settings: 'SOFT' 40, 'opsz' 14; color: var(--ink);">
        HiQ Cortex
      </span>
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="smallcaps" style="text-decoration: none; color: var(--ink-mute);">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a href={otherLocale.href} class="smallcaps" style="text-decoration: none; color: var(--ink-faint);">
        {otherLocale.label}
      </a>
      <a href="/chat" class="ticket" style="padding: 0.5rem 1rem;">{chatLabel} <span aria-hidden="true">→</span></a>
    </div>
  </div>
</header>
