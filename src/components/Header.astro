---
interface Props {
  locale?: 'en' | 'zh';
}
const { locale = 'en' } = Astro.props;

const nav = locale === 'zh'
  ? [
      { href: '/zh/solutions/bom-matching', label: '方案' },
      { href: '/zh/methodology', label: '方法学' },
      { href: '/zh/blog', label: '博客' },
      { href: '/zh/docs', label: '文档' },
    ]
  : [
      { href: '/solutions/bom-matching', label: 'Solutions' },
      { href: '/methodology', label: 'Methodology' },
      { href: '/blog', label: 'Blog' },
      { href: '/docs', label: 'Docs' },
    ];

const home = locale === 'zh' ? '/zh' : '/';
const chatLabel = locale === 'zh' ? '打开 Chat' : 'Open Chat';
const otherLocale = locale === 'zh' ? { href: '/', label: 'EN' } : { href: '/zh', label: '中文' };
---

<header class="border-b border-stone-200/70 dark:border-stone-800/70">
  <div class="container-wide flex h-16 items-center justify-between">
    <a href={home} class="flex items-center gap-2 font-sans text-base font-semibold tracking-tight">
      <img src="/snail.svg" alt="" class="h-6 w-6" aria-hidden="true" />
      <span>HiQ Cortex</span>
    </a>
    <nav class="hidden items-center gap-6 text-sm text-quiet md:flex">
      {nav.map((item) => (
        <a href={item.href} class="transition-colors hover:text-stone-900 dark:hover:text-stone-50">
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-3 text-sm">
      <a href={otherLocale.href} class="text-quiet hover:text-stone-900 dark:hover:text-stone-50">
        {otherLocale.label}
      </a>
      <a
        href="/chat"
        class="rounded-md border border-stone-300 bg-stone-50 px-3 py-1.5 font-medium text-stone-900 transition-colors hover:border-shell-500 hover:text-shell-700 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-50 dark:hover:border-shell-400 dark:hover:text-shell-300"
      >
        {chatLabel}
      </a>
    </div>
  </div>
</header>
