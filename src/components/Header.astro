---
import ThemeToggle from './ThemeToggle.astro';

interface Props { locale?: 'en' | 'zh' }
const { locale = 'en' } = Astro.props;

const nav = locale === 'zh'
  ? [
      { href: '/zh/product/chat',   label: 'Chat' },
      { href: '/zh/product/cowork', label: 'Cowork' },
      { href: '/zh/standards',      label: '标准' },
      { href: '/zh/docs',           label: 'API' },
      { href: '/zh/blog',           label: '博客' },
    ]
  : [
      { href: '/product/chat',   label: 'Chat' },
      { href: '/product/cowork', label: 'Cowork' },
      { href: '/standards',      label: 'Standards' },
      { href: '/docs',           label: 'API' },
      { href: '/blog',           label: 'Blog' },
    ];

const home = locale === 'zh' ? '/zh' : '/';
const chatLabel = locale === 'zh' ? '打开 Chat' : 'Open Chat';
const otherLocale = locale === 'zh' ? { href: '/', label: 'EN' } : { href: '/zh', label: '中文' };
---

<header class="relative z-20 border-b border-rule">
  <div class="container-page flex h-16 items-center justify-between">
    <a href={home} class="group flex items-center gap-3 no-underline" style="text-decoration: none;" aria-label="HiQ Cortex home">
      <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" style="color: var(--ink);">
        <g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 23 C 4 26, 7 27, 10 27 L 23 27 C 27 27, 28 25, 27 22 C 25 20, 20 20, 16 21 C 12 20, 8 20, 5 23 Z"/>
          <path d="M6 22 C 4 19, 5 15, 7 13"/>
          <circle cx="7" cy="12.4" r="1" fill="currentColor" stroke="none"/>
          <path d="M9 22 C 9 18, 11 15, 12 13.5"/>
          <circle cx="12" cy="12.8" r="1" fill="currentColor" stroke="none"/>
          <circle cx="8.5" cy="25" r="0.7" fill="currentColor" stroke="none"/>
          <circle cx="19" cy="16" r="6.5"/>
          <path d="M19 16 m-3.5 0 a3.5 3.5 0 1 1 7 0 a2.5 2.5 0 1 1 -5 0 a1.5 1.5 0 1 1 3 0 a0.6 0.6 0 1 1 -1.2 0"/>
        </g>
      </svg>
      <span class="font-display text-[1.08rem] font-medium tracking-tight" style="font-variation-settings: 'SOFT' 40, 'opsz' 14; color: var(--ink);">
        HiQ Cortex
      </span>
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="smallcaps" style="text-decoration: none; color: var(--ink-mute);">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a href={otherLocale.href} class="smallcaps" style="text-decoration: none; color: var(--ink-faint);">
        {otherLocale.label}
      </a>
      <a href="/chat" class="ticket" style="padding: 0.5rem 1rem;">{chatLabel} <span aria-hidden="true">→</span></a>
    </div>
  </div>
</header>
