---
/**
 * Naturalist-illustration snail, side view — head on LEFT, shell on back,
 * tapered tail on RIGHT, two antennae with eye dots, foot ripples.
 * Uses currentColor so it inherits ink; inline SVG so CSS animates the trail.
 */
interface Props {
  class?: string;
  trail?: boolean;
  size?: number;
}
const { class: klass = '', trail = true, size = 320 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 520 360"
  width={size}
  height={Math.round((size * 360) / 520)}
  class:list={['snail-glyph', klass]}
  aria-hidden="true"
  role="img"
>
  <!-- Trail — faint dotted arc behind the tail, right side -->
  {trail && (
    <path class="snail-trail-path" d="M 512 344 C 492 336, 478 328, 468 316 C 462 306, 462 300, 468 296" />
  )}

  <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">

    <!-- Body silhouette: head (left) → foot (bottom) → tail (right-taper) → upper back → head.
         Top edge has gentle undulations so the shell sits on a living surface, not a block. -->
    <path d="M 74 290
             C 60 296, 56 310, 78 314
             L 440 314
             C 472 314, 480 296, 468 282
             C 448 268, 412 274, 376 280
             C 336 274, 292 272, 248 278
             C 204 274, 156 272, 112 278
             C 88 278, 74 282, 74 290 Z" />

    <!-- Foot ripple — small scallops along the bottom to suggest the moving sole -->
    <g stroke-width="0.9" opacity="0.55">
      <path d="M 110 314 q 8 4 16 0" />
      <path d="M 166 314 q 8 4 16 0" />
      <path d="M 222 314 q 8 4 16 0" />
      <path d="M 278 314 q 8 4 16 0" />
      <path d="M 334 314 q 8 4 16 0" />
      <path d="M 390 314 q 8 4 16 0" />
    </g>

    <!-- Antennae — two tapering curves from the head area (top-left), with small knobs at tips -->
    <path d="M 82 280 C 66 254, 64 222, 80 198" stroke-width="1.7" />
    <circle cx="80" cy="196" r="4" fill="currentColor" stroke="none" />
    <path d="M 104 278 C 98 246, 118 214, 132 198" stroke-width="1.7" />
    <circle cx="132" cy="196" r="4" fill="currentColor" stroke="none" />

    <!-- Eye on the head (just a small dot near the face) -->
    <circle cx="92" cy="302" r="2.6" fill="currentColor" stroke="none" />

    <!-- Mouth hint — short line under the eye -->
    <path d="M 80 310 l 10 1" stroke-width="1" opacity="0.7" />

    <!-- Shell: resting on the upper back, center-right. Outer ring, then spiral coils. -->
    <circle cx="300" cy="206" r="86" stroke-width="2.1" />

    <!-- Spiral — concentric semi-closed arcs, reads as a cross-section of the shell -->
    <path d="M 300 206
             m -66 0
             a 66 66 0 1 1 132 0
             a 51 51 0 1 1 -102 0
             a 38 38 0 1 1 76 0
             a 26 26 0 1 1 -52 0
             a 15 15 0 1 1 30 0
             a 6 6 0 1 1 -12 0"
          stroke-width="1.6" />

    <!-- Radial hatching — suggests 3D curvature of the shell -->
    <g stroke-width="0.9" opacity="0.55">
      <path d="M 236 194 Q 248 174 266 164" />
      <path d="M 236 220 Q 248 240 264 250" />
      <path d="M 364 194 Q 362 174 344 164" />
      <path d="M 364 220 Q 362 240 346 250" />
      <path d="M 278 124 Q 300 118 322 124" />
      <path d="M 268 288 Q 300 292 332 288" />
    </g>

    <!-- Stipple — small texture dots on the shell -->
    <g fill="currentColor" stroke="none" opacity="0.5">
      <circle cx="262" cy="180" r="1" />
      <circle cx="286" cy="166" r="1" />
      <circle cx="318" cy="170" r="1" />
      <circle cx="336" cy="188" r="1" />
      <circle cx="302" cy="232" r="1" />
      <circle cx="272" cy="228" r="1" />
      <circle cx="328" cy="232" r="1" />
      <circle cx="310" cy="198" r="1" />
    </g>
  </g>
</svg>
