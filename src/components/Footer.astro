---
interface Props { locale?: 'en' | 'zh' }
const { locale = 'en' } = Astro.props;
const year = new Date().getFullYear();

const copy = locale === 'zh'
  ? {
      tag: '一条能被逐条复核的推理链。',
      set: '正文 Newsreader，标题 Fraunces，数据 JetBrains Mono。',
      groups: [
        { title: '产品', links: [
          { href: '/zh/product/chat', label: 'Cortex Chat' },
          { href: '/zh/product/cowork', label: 'Cortex Cowork' },
        ]},
        { title: '洞察', links: [
          { href: '/zh/blog', label: '博客' },
          { href: '/zh/about', label: '关于' },
        ]},
        { title: '参考', links: [
          { href: '/zh/methodology', label: '方法学' },
          { href: '/zh/standards', label: '标准对齐' },
          { href: '/zh/docs', label: '文档' },
        ]},
        { title: '公司', links: [
          { href: 'https://hiq.earth', label: 'HiQ-AI 总站' },
          { href: 'mailto:contact@hiq.earth', label: '联系' },
        ]},
      ],
    }
  : {
      tag: 'A chain of reasoning you can audit, line by line.',
      set: 'Body set in Newsreader. Display in Fraunces. Data in JetBrains Mono.',
      groups: [
        { title: 'Products', links: [
          { href: '/product/chat', label: 'Cortex Chat' },
          { href: '/product/cowork', label: 'Cortex Cowork' },
        ]},
        { title: 'Insights', links: [
          { href: '/blog', label: 'Blog' },
          { href: '/about', label: 'About' },
        ]},
        { title: 'Reference', links: [
          { href: '/methodology', label: 'Methodology' },
          { href: '/standards', label: 'Standards' },
          { href: '/docs', label: 'Docs' },
        ]},
        { title: 'Company', links: [
          { href: 'https://hiq.earth', label: 'HiQ-AI (main)' },
          { href: 'mailto:contact@hiq.earth', label: 'Contact' },
        ]},
      ],
    };
---

<footer class="mt-32 border-t border-rule">
  <div class="container-page grid gap-12 py-16 md:grid-cols-[1.2fr_3fr]">
    <div>
      <div class="flex items-center gap-3" style="color: var(--ink-mute);">
        <svg viewBox="0 0 32 32" width="24" height="24" aria-hidden="true">
          <g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 23 C 4 26, 7 27, 10 27 L 23 27 C 27 27, 28 25, 27 22 C 25 20, 20 20, 16 21 C 12 20, 8 20, 5 23 Z"/>
            <path d="M6 22 C 4 19, 5 15, 7 13"/>
            <circle cx="7" cy="12.4" r="1" fill="currentColor" stroke="none"/>
            <path d="M9 22 C 9 18, 11 15, 12 13.5"/>
            <circle cx="12" cy="12.8" r="1" fill="currentColor" stroke="none"/>
            <circle cx="8.5" cy="25" r="0.7" fill="currentColor" stroke="none"/>
            <circle cx="19" cy="16" r="6.5"/>
            <path d="M19 16 m-3.5 0 a3.5 3.5 0 1 1 7 0 a2.5 2.5 0 1 1 -5 0 a1.5 1.5 0 1 1 3 0 a0.6 0.6 0 1 1 -1.2 0"/>
          </g>
        </svg>
        <span class="font-display" style="font-variation-settings: 'SOFT' 40; color: var(--ink);">HiQ Cortex</span>
      </div>
      <p class="mt-4 max-w-xs font-serif italic" style="font-variation-settings: 'opsz' 14; color: var(--ink-faint);">{copy.tag}</p>
    </div>
    <div class="grid grid-cols-2 gap-10 sm:grid-cols-4">
      {copy.groups.map((group) => (
        <div>
          <div class="eyebrow mb-4">{group.title}</div>
          <ul class="space-y-2.5">
            {group.links.map((l) => (
              <li><a href={l.href} class="font-serif text-sm" style="text-decoration: none; font-variation-settings: 'opsz' 14; color: var(--ink);">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="border-t border-rule">
    <div class="container-page grid grid-cols-1 items-center gap-3 py-5 md:grid-cols-3">
      <div class="running-footer">© {year} HiQ-AI</div>
      <div class="text-center font-serif italic" style="font-variation-settings: 'opsz' 14; letter-spacing: 0; color: var(--ink-faint); font-size: 0.82rem;">{copy.set}</div>
      <div class="running-footer text-right">cortex.hiq.earth</div>
    </div>
  </div>
</footer>
