---
import '@/styles/global.css';
import SiteHead from '@/components/SiteHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description: string;
  locale?: 'en' | 'zh';
  canonical?: string;
  ogImage?: string;
}

const { title, description, locale = 'en', canonical, ogImage } = Astro.props;
const lang = locale === 'zh' ? 'zh-CN' : 'en';
---

<!doctype html>
<html lang={lang} class="h-full">
  <head>
    <SiteHead title={title} description={description} canonical={canonical} ogImage={ogImage} />
  </head>
  <body class="flex min-h-full flex-col font-serif" style="font-variation-settings: 'opsz' 16;">
    <Header locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
